RewriteEngine On

# ============================================================
# 410 GONE — Ancien contenu WordPress (libère le crawl budget)
# ============================================================
RewriteRule ^wp-content/.*$ - [R=410,L]
RewriteRule ^wp-admin/.*$ - [R=410,L]
RewriteRule ^feed/?$ - [R=410,L]
RewriteRule ^comments/feed/?$ - [R=410,L]

# ============================================================
# FORCE UTF-8 CHARSET
# ============================================================
AddDefaultCharset UTF-8
AddType 'text/html; charset=UTF-8' .php .html

# ============================================================
# FORCE HTTPS + WWW
# ============================================================
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.cemarenov.fr/$1 [R=301,L]

# ============================================================
# CANONICAL URL (self-canonical via HTTP Link header)
# S'applique uniquement une fois sur https://www. (après les
# 301 ci-dessus). Chaque URL est son propre canonical.
# Les versions http:// ou sans www sont donc canonicalisées
# via le 301, et https://www. est self-canonical.
# ============================================================
RewriteRule ^ - [E=CANONICAL_PATH:%{REQUEST_URI}]
Header always set Link "<https://www.cemarenov.fr%{CANONICAL_PATH}e>; rel=\"canonical\""

# ============================================================
# 301 REDIRECTS — Old WP URLs + suppressed thin pages → articles indexés
# ============================================================

# --- Chauffage / Énergie ---
RewriteRule ^chauffage/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^chauffage/ballon-thermodynamique/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^chauffage/pompe-a-chaleur-air-air/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^chauffage/pompe-a-chaleur-air-eau/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^chauffage/triple-c-r32-chauffe-eau-thermodynamique-multi-splits/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^ballon-thermodynamique/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^pompe-a-chaleur-air-air/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^pompe-a-chaleur-air-eau/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]

# --- Énergies Solaire ---
RewriteRule ^energies-solaire/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^energies-solaire/panneaux-photovoltaiques/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]
RewriteRule ^panneaux-photovoltaiques/?$ /chauffe-eau-thermodynamique-triple-c [R=301,L]

# --- Traitement de l'eau ---
RewriteRule ^traitement-de-leau/?$ /adoucisseur-deau [R=301,L]
RewriteRule ^traitement-de-leau/adoucisseur-deau/?$ /adoucisseur-deau [R=301,L]

# --- Ventilation ---
RewriteRule ^ventilation/?$ /vmc-double-flux [R=301,L]
RewriteRule ^ventilation/extracteur-dair-a-energie-solaire-pour-combles/?$ /extracteur-dair-solaire-combles [R=301,L]
RewriteRule ^ventilation/ventilation-naturelle/?$ /ventilation-naturelle [R=301,L]
RewriteRule ^ventilation/ventilation-par-surpression/?$ /vmc-double-flux [R=301,L]
RewriteRule ^ventilation/vmc-double-flux/?$ /vmc-double-flux [R=301,L]
RewriteRule ^ventilation/vmc-simple-flux/?$ /vmc-double-flux [R=301,L]
RewriteRule ^ventilation-par-surpression/?$ /vmc-double-flux [R=301,L]
RewriteRule ^vmc-simple-flux/?$ /vmc-double-flux [R=301,L]

# --- Charpente ---
RewriteRule ^charpente/?$ /traitement-curatif-charpente [R=301,L]
RewriteRule ^charpente/traitement-curatif/?$ /traitement-curatif-charpente [R=301,L]
RewriteRule ^charpente/traitement-preventif/?$ /traitement-curatif-charpente [R=301,L]
RewriteRule ^traitement-preventif-charpente/?$ /traitement-curatif-charpente [R=301,L]

# --- Couverture ---
RewriteRule ^couverture/?$ /changement-de-couverture [R=301,L]
RewriteRule ^couverture/changement-de-couverture/?$ /changement-de-couverture [R=301,L]
RewriteRule ^couverture/faitage/?$ /dosage-mortier-batard-faitage [R=301,L]
RewriteRule ^couverture/abergement-de-cheminee/?$ /abergement-de-cheminee [R=301,L]
RewriteRule ^couverture/remaniement-de-couverture/?$ /changement-de-couverture [R=301,L]
RewriteRule ^couverture/accessoires-et-finitions/?$ /gouttieres [R=301,L]
RewriteRule ^couverture/accessoires-et-finitions/dessous-de-toit/?$ /gouttieres [R=301,L]
RewriteRule ^couverture/accessoires-et-finitions/gouttieres/?$ /gouttieres [R=301,L]
RewriteRule ^faitage/?$ /dosage-mortier-batard-faitage [R=301,L]
RewriteRule ^remaniement-de-couverture/?$ /changement-de-couverture [R=301,L]
RewriteRule ^dessous-de-toit/?$ /gouttieres [R=301,L]

# --- Façade ---
RewriteRule ^facade/?$ /crepi-facade [R=301,L]
RewriteRule ^facade/ravalement-de-facade/?$ /crepi-facade [R=301,L]
RewriteRule ^facade/ravalement-de-facade/le-bardage-decoratif/?$ /bardage-bois-sur-mur-parpaing [R=301,L]
RewriteRule ^facade/ravalement-de-facade/le-crepi/?$ /crepi-facade [R=301,L]
RewriteRule ^facade/ravalement-de-facade/lenduit-a-pierre-vue/?$ /enduit-pierre-vue [R=301,L]
RewriteRule ^facade/ravalement-de-facade/lenduit/?$ /enduit-pierre-vue [R=301,L]
RewriteRule ^facade/renovation-de-facade/?$ /crepi-facade [R=301,L]
RewriteRule ^facade/renovation-de-facade/hydrofuge-incolore-de-facade/?$ /nettoyage-demoussage-facade [R=301,L]
RewriteRule ^facade/renovation-de-facade/nettoyage-demoussage/?$ /nettoyage-demoussage-facade [R=301,L]
RewriteRule ^facade/renovation-de-facade/peinture-de-facade/?$ /peinture-isolante-facade [R=301,L]
RewriteRule ^facade/renovation-de-facade/peinture-isolante-de-facade/?$ /peinture-isolante-facade [R=301,L]
RewriteRule ^facade/traitement-d-humidite/?$ /assechement-murs-injections [R=301,L]
RewriteRule ^facade/traitement-d-humidite/assechement-des-murs-par-injections/?$ /assechement-murs-injections [R=301,L]
RewriteRule ^facade/traitement-d-humidite/inverseur-de-polarite-electromagnetique/?$ /assechement-murs-injections [R=301,L]
RewriteRule ^ravalement-de-facade/?$ /crepi-facade [R=301,L]
RewriteRule ^renovation-de-facade/?$ /crepi-facade [R=301,L]
RewriteRule ^bardage-decoratif/?$ /bardage-bois-sur-mur-parpaing [R=301,L]
RewriteRule ^enduit-facade/?$ /enduit-pierre-vue [R=301,L]
RewriteRule ^hydrofuge-incolore-facade/?$ /nettoyage-demoussage-facade [R=301,L]
RewriteRule ^peinture-de-facade/?$ /peinture-isolante-facade [R=301,L]
RewriteRule ^traitement-humidite/?$ /assechement-murs-injections [R=301,L]
RewriteRule ^inverseur-polarite-electromagnetique/?$ /assechement-murs-injections [R=301,L]

# --- Toiture ---
RewriteRule ^toiture/?$ /nettoyage-toiture-karcher [R=301,L]
RewriteRule ^toiture/hydrofuge-de-toiture/?$ /nettoyage-toiture-karcher [R=301,L]
RewriteRule ^toiture/hydrofuge-de-toiture/hydrofuge-colore/?$ /nettoyage-toiture-karcher [R=301,L]
RewriteRule ^toiture/hydrofuge-de-toiture/hydrofuge-incolore/?$ /nettoyage-toiture-karcher [R=301,L]
RewriteRule ^toiture/nettoyage-demoussage/?$ /nettoyage-demoussage-facade [R=301,L]
RewriteRule ^toiture/peinture-thermique/?$ /nettoyage-toiture-karcher [R=301,L]
RewriteRule ^hydrofuge-de-toiture/?$ /nettoyage-toiture-karcher [R=301,L]
RewriteRule ^hydrofuge-colore-toiture/?$ /nettoyage-toiture-karcher [R=301,L]
RewriteRule ^hydrofuge-incolore-toiture/?$ /nettoyage-toiture-karcher [R=301,L]
RewriteRule ^peinture-thermique-toiture/?$ /nettoyage-toiture-karcher [R=301,L]

# --- Travaux ---
RewriteRule ^travaux-planning-ma-gestion-renovation-fr/?$ /travaux-planning-ma-gestion-renovation [R=301,L]

# --- Isolation ---
RewriteRule ^isolation/?$ /isolation-thermique-interieur-iti [R=301,L]
RewriteRule ^isolation/isolation-des-combles-perdus/?$ /isolation-des-combles-perdus [R=301,L]
RewriteRule ^isolation/isolation-des-murs/?$ /isolation-thermique-interieur-iti [R=301,L]
RewriteRule ^isolation/isolation-des-murs/lisolation-thermique-par-lexterieur-ite/?$ /isolation-thermique-interieur-iti [R=301,L]
RewriteRule ^isolation/isolation-des-murs/lisolation-thermique-par-linterieur-iti/?$ /isolation-thermique-interieur-iti [R=301,L]
RewriteRule ^isolation/isolation-sous-rampants-sous-toiture/?$ /isolation-sous-rampants-toiture [R=301,L]
RewriteRule ^isolation-des-murs/?$ /isolation-thermique-interieur-iti [R=301,L]
RewriteRule ^isolation-thermique-exterieur-ite/?$ /isolation-thermique-interieur-iti [R=301,L]

# ============================================================
# CLEAN URLs — Remove .php extensions
# ============================================================

# If the request is not a file or directory, try adding .php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Blog articles: /slug → /blog/slug.php
RewriteCond %{DOCUMENT_ROOT}/blog/%{REQUEST_URI}.php -f
RewriteRule ^([a-z0-9-]+)$ blog/$1.php [L]

# Search page: /recherche?q=... → search.php?q=...
RewriteRule ^recherche$ search.php [L,QSA]

# Root pages: /slug → /slug.php
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([a-z0-9-]+)/?$ $1.php [L]

# Category pages (already handled by individual files like renovation.php, travaux.php, etc.)

# ============================================================
# CACHE & COMPRESSION
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType text/css               "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2             "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
